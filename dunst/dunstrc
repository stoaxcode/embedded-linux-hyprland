[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    ### Geometry ###
    width = (0, 400)
    height = 300
    origin = bottom-right
    offset = 20x20
    
    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 400
    
    ### Text ###
    font = JetBrainsMono Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    ### Icons ###
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_path = /usr/share/icons/Papirus-Dark/48x48/status/:/usr/share/icons/Papirus-Dark/48x48/devices/
    
    ### History ###
    sticky_history = yes
    history_length = 20
    
    ### Misc ###
    dmenu = /usr/bin/wofi -dmenu -p dunst:
    browser = /usr/bin/firefox
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 8
    ignore_dbusclose = false
    
    ### Mouse ###
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

# Blue Electronics

[urgency_low]
    background = "#0A0E14EE"
    foreground = "#00D9FF"
    frame_color = "#00A2FF"
    timeout = 5
    icon = dialog-information

[urgency_normal]
    background = "#0A0E14F5"
    foreground = "#00FFFF"
    frame_color = "#00D9FF"
    highlight = "#00D9FF"
    timeout = 8
    icon = dialog-information

[urgency_critical]
    background = "#0A0E14FF"
    foreground = "#FF4444"
    frame_color = "#FF4444"
    highlight = "#FF4444"
    timeout = 0
    icon = dialog-error

# CUSTOM RULES - Hypridle Notifications

[hypridle]
    appname = Hypridle
    background = "#0A0E14F8"
    foreground = "#00FFFF"
    frame_color = "#00D9FF"
    format = "<span foreground='#00D9FF'><b>%s</b></span>\n<span foreground='#00FFFF'>%b</span>"
    timeout = 5
    icon = computer