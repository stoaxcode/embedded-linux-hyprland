{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 0,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    
    "modules-left": ["custom/logo", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "temperature", "battery", "tray", "custom/power"],

    // Custom logo (electronics themed)
    "custom/logo": {
        "format": " ",
        "tooltip": false,
        "on-click": "wofi --show drun"
    },

    // Workspaces - Embedded workflow
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "CODE",
            "2": "FILE",
            "3": "FLASH",
            "4": "UART",
            "5": "DOCS",
            "6": "SYS"
        },
        "persistent-workspaces": {
            "*": 6
        }
    },

    "hyprland/window": {
        "format": ">> {}",
        "max-length": 60,
        "separate-outputs": true
    },

    "clock": {
        "timezone": "Asia/Manila",
        "format": " {:%H:%M:%S}",
        "format-alt": " {:%Y-%m-%d %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "cpu": {
        "format": "CPU {usage:02}%",
        "tooltip": true,
        "interval": 1
    },

    "memory": {
        "format": "RAM {percentage:02}%",
        "tooltip-format": "Used: {used:0.1f}GB / {total:0.1f}GB"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "TMP {temperatureC}°C",
        "format-critical": "HOT {temperatureC}°C"
    },

    "network": {
        "format-wifi": "NET {signalStrength}%",
        "format-ethernet": "ETH {ipaddr}",
        "format-disconnected": "NET ✕",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "VOL {volume:02}%",
        "format-muted": "VOL MUTE",
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity:02}%",
        "format-charging": "CHG {capacity:02}%",
        "format-plugged": "PWR {capacity:02}%"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "wlogout"
    }
}